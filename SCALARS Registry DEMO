          <div className="p-6 flex items-center gap-4 border-b-2 border-black shadow-[0_2px_5px_rgba(255,255,255,0.05)] bg-gradient-to-b from-white/5 to-transparent">
             <div className="w-12 h-12 relative flex items-center justify-center rounded-full bg-black border-[3px] border-slate-800 shadow-[inset_0_2px_5px_rgba(0,0,0,1),_0_2px_4px_rgba(255,255,255,0.1)] overflow-hidden">
                <style>
                    {`@keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }`}
                </style>
                <svg className="w-[120%] h-[120%] text-indigo-500 drop-shadow-[0_0_5px_rgba(99,102,241,1)]" viewBox="0 0 100 100" fill="none" style={{ animation: 'spin-slow 8s linear infinite' }}>
                    <circle cx="50" cy="50" r="4" fill="white" />
                    <path d="M10 50 Q 30 30 50 50 T 90 50" stroke="currentColor" strokeWidth="3" />
                    <path d="M10 50 Q 30 70 50 50 T 90 50" stroke="currentColor" strokeWidth="3" transform="rotate(45 50 50)" />
                    <path d="M10 50 Q 30 30 50 50 T 90 50" stroke="currentColor" strokeWidth="3" transform="rotate(90 50 50)" />
                    <path d="M10 50 Q 30 70 50 50 T 90 50" stroke="currentColor" strokeWidth="3" transform="rotate(135 50 50)" />
                </svg>
             </div>
             <span className="text-2xl font-black tracking-[0.2em] text-white drop-shadow-md">SCALARS</span>
          </div>

          {/* Navigation Controls */}
          <div className="px-4 py-6 space-y-2 flex-1 overflow-y-auto">
            <div className="mb-2 pl-2 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Core Systems</div>
            <NavItem id="dashboard" label="Command Center" icon={Activity} />
            <NavItem id="registry" label="Global Registry" icon={Database} />
            <NavItem id="mint" label="ASMT Forge" icon={Cpu} />
            <NavItem id="governance" label="Ring Council" icon={Vote} />
            
            <div className="mt-8 mb-2 pl-2 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Planetary Modules</div>
            <NavItem id="harvest" label="Harvest Grid" icon={Leaf} />
            <NavItem id="bio" label="Bio-State" icon={HeartPulse} />
            <NavItem id="dev" label="Dev Console" icon={Terminal} />
          </div>
          
          {/* Identity Plate */}
          <div className="p-4 bg-black/80 border-t-2 border-slate-800">
               <div className="flex items-center gap-4 bg-slate-900 border border-slate-700 p-3 rounded-2xl shadow-inner cursor-pointer hover:bg-slate-800 transition-colors">
                  <div className="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-emerald-500 border-2 border-black shadow-[0_0_10px_rgba(255,255,255,0.2)]"></div>
                  <div>
                      <p className="text-xs font-bold text-white uppercase tracking-widest">Architect Node</p>
                      <div className="flex items-center gap-2 mt-1">
                        <LED color="green" />
                        <p className="text-[10px] text-slate-400 font-mono">0x71C...9A23</p>
                      </div>
                  </div>
               </div>
          </div>
        </aside>
      )}

      {/* Main App Content Area */}
      <div className="flex-1 flex flex-col relative z-10 overflow-hidden">
        {/* Header Strip */}
        <header className="h-16 bg-gradient-to-b from-white/5 to-transparent border-b border-white/5 flex items-center justify-between px-6 z-40 backdrop-blur-sm">
          <div className="flex items-center gap-3">
             {appFormat === 'mobile' && (
                <div className="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center border border-indigo-500/50">
                  <Activity className="text-indigo-400" size={16} />
                </div>
             )}
          </div>
          
          <div className="ml-auto flex items-center gap-4">
             <div className="flex items-center px-4 py-1.5 bg-black/60 rounded-full border border-black shadow-[inset_0_1px_2px_rgba(255,255,255,0.1)]">
                <LED color="green" pulse className="mr-2" />
                <span className="text-[10px] font-black tracking-widest uppercase text-slate-300">Cymos Mainnet</span>
             </div>
             {appFormat === 'web' && (
               <button className="w-10 h-10 rounded-full bg-slate-800 border border-slate-600 flex items-center justify-center shadow-lg hover:bg-slate-700 transition-colors">
                  <Settings size={18} className="text-slate-300" />
               </button>
             )}
          </div>
        </header>

        {/* Scrollable Viewport */}
        <main className="flex-1 overflow-y-auto p-4 md:p-8 relative custom-scrollbar pb-24 md:pb-8">
           <div className="max-w-6xl mx-auto h-full">
             {activeTab === 'dashboard' && <DashboardView />}
             {activeTab === 'registry' && <RegistryView />}
             {activeTab === 'mint' && <MintView />}
             {activeTab === 'governance' && <GovernanceView />}
             {activeTab === 'harvest' && <HarvestView />}
             {activeTab === 'bio' && <BioMonitorView />}
             {activeTab === 'dev' && <DevConsoleView />}
           </div>
        </main>

        {/* Mobile Bottom Dock - Skeuomorphic */}
        {appFormat === 'mobile' && (
          <div className="absolute bottom-4 left-4 right-4 h-20 bg-black/80 backdrop-blur-2xl border-t border-l border-white/20 border-b border-r border-black/80 rounded-[2rem] shadow-[0_15px_30px_rgba(0,0,0,0.8),_inset_0_2px_5px_rgba(255,255,255,0.1)] flex items-center justify-around px-2 z-50">
             <MobileNavBtn id="dashboard" icon={Activity} label="CMD" />
             <MobileNavBtn id="registry" icon={Database} label="DATA" />
             <div className="-mt-10">
                {/* Huge physical center button for Mint */}
                <button onClick={()=>setActiveTab('mint')} className="w-16 h-16 rounded-full bg-gradient-to-b from-indigo-500 to-indigo-700 border-[4px] border-slate-900 shadow-[0_10px_20px_rgba(0,0,0,0.8),_inset_0_2px_5px_rgba(255,255,255,0.4)] flex items-center justify-center active:scale-95 transition-transform">
                  <Zap size={24} className="text-white drop-shadow-[0_0_5px_rgba(255,255,255,0.8)]" />
                </button>
             </div>
             <MobileNavBtn id="harvest" icon={Leaf} label="NODES" />
             <MobileNavBtn id="bio" icon={HeartPulse} label="BIO" />
          </div>
        )}
      </div>

      {/* Notifications */}
      <div className="fixed top-4 left-1/2 -translate-x-1/2 z-[100] space-y-2 pointer-events-none">
        {notifications.map(n => (
            <div key={n.id} className="bg-emerald-900/90 backdrop-blur-xl border-2 border-emerald-500 shadow-[0_10px_30px_rgba(0,0,0,0.5)] text-white px-6 py-3 rounded-full flex items-center gap-3 animate-in slide-in-from-top-4 fade-in duration-300">
                <LED color="green" pulse />
                <span className="text-xs font-black uppercase tracking-widest">{n.msg}</span>
            </div>
        ))}
      </div>
      
    </div>
  );

  // --- RENDER APP SHELL ---
  return (
    <div className="w-full h-screen bg-[#0a0a0a] flex items-center justify-center overflow-hidden font-sans">
       
       {/* Device Toggle Floating Controls */}
       <div className="fixed top-4 right-4 z-[999] flex gap-1 p-1.5 bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 shadow-2xl">
          <button 
            onClick={() => setAppFormat('web')} 
            className={`p-2.5 rounded-xl transition-all ${appFormat === 'web' ? 'bg-indigo-600 text-white shadow-inner' : 'text-slate-400 hover:text-white hover:bg-white/5'}`}
            title="Desktop Interface"
          >
             <Monitor size={18} />
          </button>
          <button 
            onClick={() => setAppFormat('mobile')} 
            className={`p-2.5 rounded-xl transition-all ${appFormat === 'mobile' ? 'bg-indigo-600 text-white shadow-inner' : 'text-slate-400 hover:text-white hover:bg-white/5'}`}
            title="Mobile Interface"
          >
             <Smartphone size={18} />
          </button>
       </div>

       {/* Outer Frame (Simulates Device constraints if mobile) */}
       <div 
         className={`relative overflow-hidden bg-black transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]
           ${appFormat === 'mobile' 
             ? 'w-[400px] h-[850px] rounded-[3.5rem] border-[14px] border-slate-900 shadow-[0_20px_50px_rgba(0,0,0,0.8),_0_0_0_2px_rgba(255,255,255,0.1)] ring-8 ring-black' 
             : 'w-full h-full rounded-none border-0'
           }`
         }
       >
          {/* Dynamic Notch for mobile */}
          {appFormat === 'mobile' && (
            <div className="absolute top-0 left-1/2 -translate-x-1/2 w-40 h-7 bg-slate-900 rounded-b-3xl z-[100] flex justify-center items-end pb-1 shadow-inner">
               <div className="w-16 h-1.5 bg-black rounded-full opacity-50"></div>
            </div>
          )}

          {renderContent()}
       </div>

       <style dangerouslySetInnerHTML={{__html: `
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.4); }
      `}} />
    </div>
  );
}


